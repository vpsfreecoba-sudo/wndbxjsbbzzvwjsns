{
    "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
    "files": {
        "ignore": ["dist/**", "node_modules/**"]
    },
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useConst": "error"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    }
}
